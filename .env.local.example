# ============================================================
# CREDAI Member Portal — Environment Variables Reference
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or any file with real secrets.
# All variables listed here are validated at boot via src/env.js.
# ============================================================

# --- Database ---
DATABASE_URL="postgresql://credai:dev123@localhost:5432/credai"

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="<run: openssl rand -base64 32>"

# --- Staff Auth Provider (GitHub OAuth for dev; replace with internal IdP in prod) ---
AUTH_GITHUB_ID="<your-github-oauth-app-client-id>"
AUTH_GITHUB_SECRET="<your-github-oauth-app-client-secret>"

# --- Vercel Blob (document vault) ---
BLOB_READ_WRITE_TOKEN="<vercel-blob-token>"

# --- Payment Gateway (Razorpay primary) ---
RAZORPAY_KEY_ID="rzp_test_<your-key>"
RAZORPAY_KEY_SECRET="<your-razorpay-secret>"
RAZORPAY_WEBHOOK_SECRET="<your-webhook-secret>"

# --- Payment Gateway (Cashfree fallback) ---
CASHFREE_APP_ID="<your-cashfree-app-id>"
CASHFREE_SECRET_KEY="<your-cashfree-secret>"
CASHFREE_WEBHOOK_SECRET="<your-cashfree-webhook-secret>"

# --- GST Verification ---
GST_PROVIDER="mock"
# Options: "mock" | "gstn-public" | "cdsl-licensed"
GSTN_API_KEY="<your-gstn-api-key>"
CDSL_GST_API_KEY="<your-cdsl-gst-api-key>"

# --- PAN Verification ---
PAN_PROVIDER="mock"
# Options: "mock" | "protean"
PROTEAN_PAN_API_KEY="<your-protean-api-key>"

# --- Email ---
EMAIL_PROVIDER="console"
# Options: "console" | "ses" | "sendgrid"
AWS_SES_REGION="ap-south-1"
AWS_SES_ACCESS_KEY_ID="<your-ses-access-key>"
AWS_SES_SECRET_ACCESS_KEY="<your-ses-secret>"
EMAIL_FROM="noreply@credaipune.org"

# --- AWS KMS (envelope encryption for Aadhaar, document signing) ---
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID="<your-aws-access-key>"
AWS_SECRET_ACCESS_KEY="<your-aws-secret>"
KMS_KEY_ID="<your-kms-key-arn>"

# --- Cloudflare Turnstile (CAPTCHA on public certificate verification) ---
CLOUDFLARE_TURNSTILE_SITE_KEY="<your-turnstile-site-key>"
CLOUDFLARE_TURNSTILE_SECRET_KEY="<your-turnstile-secret-key>"

# --- Rate Limiting ---
PUBLIC_VERIFY_RATE_LIMIT="100"
# Requests per minute per IP for /api/public/verify

# --- Sentry (error tracking) ---
SENTRY_DSN="<your-sentry-dsn>"
SENTRY_AUTH_TOKEN="<your-sentry-auth-token>"
NEXT_PUBLIC_SENTRY_DSN="<your-sentry-dsn>"

# --- Application ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
